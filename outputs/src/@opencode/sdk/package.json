{
  "name": "@opencode/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for OpenCode RS - Programmatic access to OpenCode capabilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mycode/opencode-rs"
  },
  "keywords": [
    "opencode",
    "sdk",
    "ai",
    "coding",
    "api-bindings",
    "developer-tools"
  ],
  "categories": [
    "API Bindings",
    "Development Tools"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false
}
