{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "permission",
  "description": "E2E test case designs for opencode-permission crate - Permission/access control system",
  "test_cases": [
    {
      "id": "permission_e2e_001",
      "status": "completed",
      "title": "Permission scope enforcement",
      "description": "Test AgentPermissionScope restricts tool execution",
      "modules": ["permission", "tool"],
      "steps": [
        "Create ReadOnly permission scope",
        "Attempt write operations",
        "Verify operations blocked",
        "Upgrade to Full scope",
        "Verify write operations allowed"
      ],
      "expected_outcomes": [
        "ReadOnly blocks dangerous operations",
        "Full scope allows all operations"
      ]
    },
    {
      "id": "permission_e2e_002",
      "status": "completed",
      "title": "Permission prompt and approval flow",
      "description": "Test permission requests and user approval",
      "modules": ["permission"],
      "steps": [
        "Attempt restricted operation",
        "Verify permission prompt generated",
        "Approve operation",
        "Verify operation completes"
      ],
      "expected_outcomes": [
        "Prompt contains operation details",
        "Approval enables operation"
      ]
    },
    {
      "id": "permission_sec_001",
      "status": "completed",
      "title": "Permission bypass via tool name confusion",
      "description": "CRITICAL: Tool name aliases must not bypass permission checks",
      "modules": ["permission", "tool"],
      "risk_addressed": "Restricted tool executed via alias",
      "preconditions": "ReadOnly scope, bash tool blocked",
      "test_data": [
        {"alias": "/usr/bin/bash", "tool": "bash"},
        {"alias": "sh", "tool": "bash"},
        {"alias": "python -c", "tool": "bash"}
      ],
      "steps": [
        "Register aliases for restricted tools",
        "Attempt to call bash via alias in ReadOnly scope",
        "Verify blocked"
      ],
      "expected_outcomes": [
        "All aliases to restricted tools blocked",
        "No bypass via name variation"
      ],
      "priority": "critical"
    },
    {
      "id": "permission_sec_002",
      "status": "completed",
      "title": "Permission scope escalation prevention",
      "description": "CRITICAL: Scope must not be modifiable at runtime",
      "modules": ["permission"],
      "risk_addressed": "Tool escalates its own permissions",
      "preconditions": "ReadOnly scope",
      "steps": [
        "Tool attempts to call 'grant_full_permissions' or similar",
        "Attempt to modify scope from within tool execution",
        "Verify all escalation attempts blocked"
      ],
      "expected_outcomes": [
        "Runtime scope modification blocked",
        "Escalation attempts logged",
        "Original scope preserved"
      ],
      "priority": "critical"
    },
    {
      "id": "permission_sec_003",
      "status": "completed",
      "title": "Permission prompt timeout",
      "description": "Unanswered permission prompts must timeout",
      "modules": ["permission"],
      "risk_addressed": "Agent hangs waiting for permission approval",
      "preconditions": "Permission prompt displayed",
      "steps": [
        "Display permission prompt",
        "Do not respond",
        "Wait for timeout",
        "Verify timeout error returned"
      ],
      "expected_outcomes": [
        "Prompt times out after configured duration",
        "Error returned to caller",
        "Operation not executed"
      ],
      "priority": "high"
    },
    {
      "id": "permission_state_001",
      "status": "completed",
      "title": "Permission state persistence",
      "description": "Approved permissions must persist across sessions or not",
      "modules": ["permission"],
      "risk_addressed": "Permanent permission grant without re-authentication",
      "preconditions": "Session with approved permissions",
      "steps": [
        "Approve 'read file X' permission",
        "End session",
        "Start new session",
        "Attempt same operation",
        "Verify re-prompt or denial"
      ],
      "expected_outcomes": [
        "Permanent approvals require explicit opt-in",
        "New session may need re-approval",
        "Temporary approvals expire"
      ],
      "priority": "medium"
    },
    {
      "id": "permission_state_002",
      "status": "completed",
      "title": "Permission approval idempotency",
      "description": "Multiple approvals of same operation handled",
      "modules": ["permission"],
      "preconditions": "Permission prompt displayed",
      "steps": [
        "Approve operation once",
        "Same operation requested again immediately",
        "Verify either auto-approved OR re-prompted"
      ],
      "expected_outcomes": [
        "Consistent behavior for repeated requests",
        "No duplicate execution",
        "Approval state tracked correctly"
      ],
      "priority": "medium"
    },
    {
      "id": "permission_scope_001",
      "status": "completed",
      "title": "Scope hierarchy enforcement",
      "description": "Nested scopes must inherit restrictions correctly",
      "modules": ["permission"],
      "risk_addressed": "Child scope less restrictive than parent",
      "preconditions": "Nested permission scope structure",
      "steps": [
        "Create parent scope: ReadOnly + no_network",
        "Create child scope inheriting parent",
        "Attempt network operation in child",
        "Verify blocked"
      ],
      "expected_outcomes": [
        "Restrictions inherited, not overridden",
        "Child cannot exceed parent permissions",
        "Weakest restriction wins"
      ],
      "priority": "high"
    },
    {
      "id": "permission_scope_002",
      "status": "completed",
      "title": "Scope bounds checking",
      "description": "Scope with file path must restrict to that path",
      "modules": ["permission"],
      "risk_addressed": "Path-bound scope allowing access outside bounds",
      "preconditions": "Scope bounded to /workspace",
      "test_data": [
        {"path": "/etc/passwd", "expected": "blocked"},
        {"path": "/workspace/file.txt", "expected": "allowed"},
        {"path": "/workspace/../etc/passwd", "expected": "blocked"}
      ],
      "steps": [
        "Scope restricts file access to /workspace",
        "Attempt access to each test path",
        "Verify correct allow/block decision"
      ],
      "expected_outcomes": [
        "Path traversal attempts blocked",
        "Within-scope paths allowed",
        "Realpath resolved before check"
      ],
      "priority": "critical"
    },
    {
      "id": "permission_audit_001",
      "status": "completed",
      "title": "Permission decisions audit logged",
      "description": "All permission grants and denials logged",
      "modules": ["permission"],
      "risk_addressed": "Unauthorized access without traceability",
      "preconditions": "Audit logging configured",
      "steps": [
        "Attempt denied operation",
        "Approve and attempt allowed operation",
        "Check audit log"
      ],
      "expected_outcomes": [
        "Denial logged with reason and timestamp",
        "Approval logged with approver",
        "Log entry includes operation and scope"
      ],
      "priority": "medium"
    }
  ],
  "test_metadata": {
    "module": "permission",
    "crate": "opencode-permission",
    "source": "crates/permission/src/lib.rs",
    "total_cases": 11,
    "category": "security",
    "critical_invariants": [
      "Tool aliases do not bypass permissions",
      "Scope escalation at runtime prevented",
      "Path-bound scopes block traversal"
    ],
    "high_risk_scenarios": [
      "permission_sec_001: Alias bypass",
      "permission_sec_002: Runtime escalation",
      "permission_scope_002: Path traversal bypass"
    ]
  }
}