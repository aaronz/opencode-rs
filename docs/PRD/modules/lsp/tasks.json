{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "lsp",
  "description": "E2E test case designs for opencode-lsp crate - Language Server Protocol integration",
  "test_cases": [
    {
      "id": "lsp_e2e_001",
      "status": "completed",
      "title": "LSP server detection and launch",
      "description": "Test LspManager detects and launches LSP servers",
      "modules": ["lsp"],
      "steps": [
        "Create project with rust-analyzer config",
        "Create LspManager",
        "Trigger detection",
        "Verify rust-analyzer launched"
      ],
      "expected_outcomes": [
        "Server detected correctly",
        "Server launched and responding"
      ]
    },
    {
      "id": "lsp_e2e_002",
      "status": "completed",
      "title": "LSP diagnostics aggregation",
      "description": "Test DiagnosticAggregator collects from all servers",
      "modules": ["lsp"],
      "steps": [
        "Start multiple LSP servers",
        "Trigger diagnostics refresh",
        "Verify all diagnostics collected",
        "Clear diagnostics"
      ],
      "expected_outcomes": [
        "Diagnostics from all servers aggregated",
        "Duplicates handled correctly"
      ]
    },
    {
      "id": "lsp_e2e_003",
      "status": "completed",
      "title": "LSP server crash recovery",
      "description": "Test LspManager restarts crashed servers",
      "modules": ["lsp"],
      "steps": [
        "Start LSP server",
        "Kill server process",
        "Trigger LSP request",
        "Verify server restarted"
      ],
      "expected_outcomes": [
        "Crash detected and logged",
        "Server restarted automatically"
      ]
    },
    {
      "id": "lsp_e2e_004",
      "status": "completed",
      "title": "Custom LSP server registration",
      "description": "Test CustomRegistry for user-defined servers",
      "modules": ["lsp"],
      "steps": [
        "Register custom LSP server",
        "Start server via manager",
        "Send initialize request",
        "Verify capabilities returned"
      ],
      "expected_outcomes": [
        "Custom server registered",
        "Capabilities match config"
      ]
    },
    {
      "id": "lsp_stability_001",
      "status": "completed",
      "title": "LSP server zombie process prevention",
      "description": "CRITICAL: Dead LSP servers must not become zombie processes",
      "modules": ["lsp"],
      "risk_addressed": "Zombie LSP processes accumulating, consuming resources",
      "preconditions": "LSP server running",
      "steps": [
        "Start LSP server",
        "Kill LSP server (kill -9 or crash)",
        "Verify no zombie process",
        "Verify process table clean",
        "Start new LSP request",
        "Verify new server starts"
      ],
      "expected_outcomes": [
        "No zombie process left",
        "Process group killed properly",
        "New requests trigger fresh server"
      ],
      "post_checks": [
        "ps aux shows no orphaned LSP processes",
        "Memory/file descriptors released"
      ],
      "priority": "critical"
    },
    {
      "id": "lsp_stability_002",
      "status": "completed",
      "title": "LSP server graceful shutdown",
      "description": "LSP server must shut down cleanly on project close",
      "modules": ["lsp"],
      "risk_addressed": "Server not shut down, resources leaked",
      "preconditions": "LSP server running for project",
      "steps": [
        "Close project",
        "Verify LSP shutdown notification sent",
        "Verify server process terminates",
        "Verify all file handles closed"
      ],
      "expected_outcomes": [
        "Shutdown request sent",
        "Server exits cleanly",
        "No orphaned processes"
      ],
      "post_checks": [
        "No lingering LSP server processes",
        "No open file handles to project files"
      ],
      "priority": "high"
    },
    {
      "id": "lsp_perf_001",
      "status": "completed",
      "title": "LSP timeout on slow server",
      "description": "LSP requests must timeout if server unresponsive",
      "modules": ["lsp"],
      "risk_addressed": "Agent hangs on slow/unresponsive LSP server",
      "preconditions": "LSP server configured",
      "steps": [
        "Configure LSP request timeout (e.g., 10s)",
        "Send request that takes 30s to respond",
        "Verify timeout error returned"
      ],
      "expected_outcomes": [
        "Timeout fires after configured duration",
        "Error returned, not hang",
        "Server still usable after timeout"
      ],
      "priority": "high"
    },
    {
      "id": "lsp_perf_002",
      "status": "completed",
      "title": "Large workspace diagnostics batching",
      "description": "Large workspace must batch diagnostics to avoid memory spike",
      "modules": ["lsp"],
      "risk_addressed": "Memory exhaustion from too many diagnostics",
      "preconditions": "Large workspace with 1000+ files",
      "steps": [
        "Open large workspace",
        "Trigger full diagnostics",
        "Measure memory usage",
        "Verify memory stays bounded"
      ],
      "expected_outcomes": [
        "Diagnostics processed in batches",
        "Memory usage stays within limit",
        "UI remains responsive"
      ],
      "priority": "medium"
    },
    {
      "id": "lsp_integ_001",
      "status": "completed",
      "title": "LSP initialization failure handling",
      "description": "Server fails to initialize but manager recovers",
      "modules": ["lsp"],
      "risk_addressed": "Single LSP failure crashes or blocks all LSP functionality",
      "preconditions": "Multiple LSP servers configured",
      "steps": [
        "Start first LSP server successfully",
        "Start second LSP server - initialize fails",
        "Verify first server still functional",
        "Retry second server",
        "Verify second server eventually initializes"
      ],
      "expected_outcomes": [
        "One server failure doesn't affect others",
        "Manager retries failed servers",
        "Errors logged but not fatal"
      ],
      "priority": "high"
    },
    {
      "id": "lsp_integ_002",
      "status": "completed",
      "title": "LSP capability mismatch handling",
      "description": "Client/server capability mismatch handled gracefully",
      "modules": ["lsp"],
      "risk_addressed": "Crash or hang when capability not supported",
      "preconditions": "Custom LSP server with limited capabilities",
      "steps": [
        "Start LSP server with limited capabilities",
        "Request capability that server doesn't support",
        "Verify graceful degradation",
        "Verify no crash"
      ],
      "expected_outcomes": [
        "Unsupported capability returns error",
        "No crash",
        "Supported capabilities still work"
      ],
      "priority": "medium"
    },
    {
      "id": "lsp_proto_001",
      "status": "completed",
      "title": "Malformed LSP message handling",
      "description": "Server sends malformed JSON-RPC message",
      "modules": ["lsp"],
      "risk_addressed": "Panic on malformed LSP message",
      "preconditions": "Mock LSP server configured",
      "test_data": [
        {"message": "not json", "issue": "invalid JSON"},
        {"message": "{\"jsonrpc\": \"1.0\"}", "issue": "wrong version"},
        {"message": "{\"id\": null}", "issue": "missing method"},
        {"message": "huge payload (10MB)", "issue": "oversized message"}
      ],
      "steps": [
        "Configure mock to send malformed messages",
        "Execute LSP request",
        "Verify manager handles gracefully"
      ],
      "expected_outcomes": [
        "Malformed message logged",
        "Manager doesn't panic",
        "Connection closed cleanly"
      ],
      "priority": "high"
    }
  ],
  "test_metadata": {
    "module": "lsp",
    "crate": "opencode-lsp",
    "source": "crates/lsp/src/lib.rs",
    "total_cases": 11,
    "category": "integration",
    "critical_invariants": [
      "Dead LSP server leaves no zombie process",
      "One server failure doesn't crash manager",
      "Malformed messages don't panic the manager"
    ],
    "high_risk_scenarios": [
      "lsp_stability_001: Zombie process leak",
      "lsp_stability_002: Resource leak on shutdown",
      "lsp_proto_001: Panic on malformed message"
    ]
  }
}