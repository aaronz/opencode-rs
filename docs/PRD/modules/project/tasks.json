{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "admin",
  "description": "E2E test case designs for admin modules - control-plane/installation/npm/skill/format/question",
  "test_cases": [
    {
      "id": "controlplane_e2e_001",
      "status": "requires_infrastructure",
      "title": "Control plane registration",
      "description": "Test registration with control plane",
      "modules": ["control-plane"],
      "steps": [
        "Create control plane client",
        "Register instance",
        "Send heartbeat",
        "Verify instance listed"
      ],
      "expected_outcomes": [
        "Registration succeeds",
        "Heartbeat acknowledged",
        "Instance visible in control plane"
      ]
    },
    {
      "id": "install_e2e_001",
      "status": "requires_infrastructure",
      "title": "Version check and update",
      "description": "Test version checking against release server",
      "modules": ["installation"],
      "steps": [
        "Check for updates",
        "Verify current version reported",
        "If update available, download",
        "Apply update"
      ],
      "expected_outcomes": [
        "Version check succeeds",
        "Update flow works correctly"
      ]
    },
    {
      "id": "npm_e2e_001",
      "status": "requires_infrastructure",
      "title": "NPM package queries",
      "description": "Test npm registry queries",
      "modules": ["npm"],
      "steps": [
        "Query package info for 'lodash'",
        "Get latest version",
        "Get dependencies",
        "Search packages"
      ],
      "expected_outcomes": [
        "Package info returned",
        "Version information correct"
      ]
    },
    {
      "id": "skill_e2e_001",
      "status": "requires_infrastructure",
      "title": "Skill registration and lookup",
      "description": "Test skills registered and discoverable",
      "modules": ["skill", "agent"],
      "steps": [
        "Register skill with name and description",
        "Lookup skill by name",
        "List all skills",
        "Execute skill action"
      ],
      "expected_outcomes": [
        "Skill registered successfully",
        "Lookup returns correct skill",
        "Actions execute correctly"
      ]
    },
    {
      "id": "format_e2e_001",
      "status": "requires_infrastructure",
      "title": "Format code with language-specific formatter",
      "description": "Test formatting with rustfmt, prettier, etc.",
      "modules": ["format"],
      "steps": [
        "Create file with unformatted Rust code",
        "Call format with Rust formatter",
        "Verify formatted output",
        "Test with TypeScript/prettier"
      ],
      "expected_outcomes": [
        "Code formatted correctly per language",
        "Formatter errors handled gracefully"
      ]
    },
    {
      "id": "question_e2e_001",
      "status": "requires_infrastructure",
      "title": "Confirmation prompt handling",
      "description": "Test yes/no confirmation flow",
      "modules": ["question"],
      "steps": [
        "Display confirmation prompt",
        "Simulate yes response",
        "Verify action taken",
        "Simulate no response",
        "Verify action not taken"
      ],
      "expected_outcomes": [
        "Prompts displayed correctly",
        "Responses handled appropriately"
      ]
    },
    {
      "id": "controlplane_001",
      "status": "requires_infrastructure",
      "title": "Control plane connection failure handling",
      "description": "Agent continues working when control plane unreachable",
      "modules": ["control-plane"],
      "risk_addressed": "Agent becomes unusable when control plane down",
      "preconditions": "Agent registered with control plane",
      "steps": [
        "Agent connected and operational",
        "Control plane becomes unreachable",
        "Verify agent continues accepting work",
        "Verify pending tasks continue"
      ],
      "expected_outcomes": [
        "Agent remains operational offline",
        "No blocking on control plane calls",
        "Reconnection happens when available"
      ],
      "priority": "high"
    },
    {
      "id": "controlplane_002",
      "status": "requires_infrastructure",
      "title": "Instance heartbeat expiration",
      "description": "Offline instances removed from control plane",
      "modules": ["control-plane"],
      "risk_addressed": "Stale instances never removed",
      "preconditions": "Instance registered",
      "steps": [
        "Instance goes offline (heartbeat stops)",
        "Wait for heartbeat timeout",
        "Verify instance removed from list"
      ],
      "expected_outcomes": [
        "Heartbeat timeout enforced",
        "Stale instances cleaned up",
        "No zombie instances"
      ],
      "priority": "medium"
    },
    {
      "id": "install_001",
      "status": "requires_infrastructure",
      "title": "Installation rollback on failure",
      "description": "Failed update must rollback to previous state",
      "modules": ["installation"],
      "risk_addressed": "Failed update leaves system broken",
      "preconditions": "Version 1.0 installed",
      "steps": [
        "Start update to version 1.1",
        "Simulate failure during install",
        "Verify rollback to 1.0",
        "Verify system still functional"
      ],
      "expected_outcomes": [
        "Rollback completes",
        "Original version restored",
        "No broken state"
      ],
      "priority": "high"
    },
    {
      "id": "install_002",
      "status": "requires_infrastructure",
      "title": "Update signature verification",
      "description": "CRITICAL: Updates must be verified before install",
      "modules": ["installation"],
      "risk_addressed": "Malicious update installed",
      "preconditions": "Update server with signed packages",
      "test_data": [
        {"update": "unsigned", "expected": "rejected"},
        {"update": "tampered", "expected": "rejected"},
        {"update": "valid_sig", "expected": "accepted"}
      ],
      "steps": [
        "Attempt install with unsigned update",
        "Attempt install with tampered update",
        "Install with valid signature"
      ],
      "expected_outcomes": [
        "Unsigned updates rejected",
        "Tampered updates rejected",
        "Valid updates accepted"
      ],
      "priority": "critical"
    },
    {
      "id": "npm_001",
      "status": "requires_infrastructure",
      "title": "NPM registry authentication",
      "description": "Private packages require auth",
      "modules": ["npm"],
      "risk_addressed": "Private packages accessed without auth",
      "preconditions": "Private npm package configured",
      "steps": [
        "Attempt to access private package without token",
        "Verify 401/403",
        "Add npm token",
        "Verify access granted"
      ],
      "expected_outcomes": [
        "Unauthenticated requests to private rejected",
        "Authenticated requests succeed"
      ],
      "priority": "high"
    },
    {
      "id": "npm_002",
      "status": "requires_infrastructure",
      "title": "NPM dependency resolution with conflicts",
      "description": "Handles version conflicts in dependency tree",
      "modules": ["npm"],
      "risk_addressed": "Wrong version installed due to conflict",
      "preconditions": "Package with conflicting dependencies",
      "steps": [
        "Package requires A@1.0 and B@1.0, both depend on C@different versions",
        "Resolve dependencies",
        "Verify consistent resolution"
      ],
      "expected_outcomes": [
        "Conflict detected",
        "Resolution strategy applied (newest/widest/override)",
        "Final tree consistent"
      ],
      "priority": "medium"
    },
    {
      "id": "skill_001",
      "status": "requires_infrastructure",
      "title": "Skill action timeout",
      "description": "Skill actions must timeout if hung",
      "modules": ["skill"],
      "risk_addressed": "Agent hangs on stuck skill",
      "preconditions": "Skill with long-running action",
      "steps": [
        "Execute skill action with 10s timeout",
        "Action takes 30s",
        "Verify timeout error returned"
      ],
      "expected_outcomes": [
        "Timeout enforced",
        "Error returned",
        "Skill system not blocked"
      ],
      "priority": "high"
    },
    {
      "id": "format_001",
      "status": "requires_infrastructure",
      "title": "Format on unsupported language",
      "description": "Graceful handling of unknown language",
      "modules": ["format"],
      "risk_addressed": "Crash on unsupported format request",
      "preconditions": "Formatter configured for common languages",
      "steps": [
        "Send .xyz file (unknown extension)",
        "Verify error returned, not crash"
      ],
      "expected_outcomes": [
        "Unsupported language returns error",
        "No crash"
      ],
      "priority": "medium"
    },
    {
      "id": "question_001",
      "status": "requires_infrastructure",
      "title": "Question timeout handling",
      "description": "Questions must timeout if unanswered",
      "modules": ["question"],
      "risk_addressed": "Agent hangs waiting for question response",
      "preconditions": "Interactive question prompt",
      "steps": [
        "Display question prompt",
        "Do not respond",
        "Wait for timeout",
        "Verify timeout error or default"
      ],
      "expected_outcomes": [
        "Timeout enforced",
        "Error returned OR default used",
        "No hang"
      ],
      "priority": "high"
    }
  ],
  "test_metadata": {
    "module": "admin",
    "crates": ["opencode-control-plane", "opencode-installation", "opencode-npm", "opencode-skill", "opencode-format", "opencode-question"],
    "total_cases": 17,
    "category": "utility",
    "critical_invariants": [
      "Agent operational without control plane",
      "Updates signature-verified before install",
      "Skill actions timeout"
    ],
    "high_risk_scenarios": [
      "install_002: Malicious update install",
      "controlplane_001: Agent blocked offline",
      "skill_001: Skill action timeout"
    ]
  }
}