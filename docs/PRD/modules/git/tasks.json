{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "git",
  "description": "E2E test case designs for opencode-git crate - Git operations wrapper",
  "test_cases": [
    {
      "id": "git_e2e_001",
      "status": "not_started",
      "title": "Git operations on repository",
      "description": "Test GitManager basic operations",
      "modules": ["git", "file"],
      "steps": [
        "Create temp directory with git repo",
        "Create GitManager",
        "Create file, git add, git commit",
        "Verify commit created",
        "Call log() and verify commit visible"
      ],
      "expected_outcomes": [
        "Repo operations work correctly",
        "Status shows file as committed"
      ]
    },
    {
      "id": "git_e2e_002",
      "status": "not_started",
      "title": "GitHub client API integration",
      "description": "Test GitHub client REST API calls",
      "modules": ["git"],
      "steps": ["Create GitHubClient with token", "Call get_repos()", "Verify returns list of repositories"],
      "expected_outcomes": [
        "API calls succeed with valid token",
        "Rate limiting handled appropriately"
      ]
    },
    {
      "id": "git_e2e_003",
      "status": "not_started",
      "title": "Branch operations",
      "description": "Test branch listing and switching",
      "modules": ["git"],
      "steps": [
        "Create GitManager on repo with multiple branches",
        "Call branches() - verify list",
        "Call current_branch() - verify HEAD",
        "Call checkout('feature-branch')",
        "Verify current_branch() updated"
      ],
      "expected_outcomes": [
        "Branches listed correctly",
        "Checkout switches HEAD"
      ]
    },
    {
      "id": "git_e2e_004",
      "status": "not_started",
      "title": "Git diff generation",
      "description": "Test diff between commits",
      "modules": ["git"],
      "steps": ["Make commit with changes", "Call diff()", "Verify diff output contains changes"],
      "expected_outcomes": [
        "Diff generated correctly",
        "Unified diff format"
      ]
    },
    {
      "id": "git_security_001",
      "status": "not_started",
      "title": "Git credentials not exposed in logs",
      "description": "CRITICAL: Git credentials must never appear in logs",
      "modules": ["git"],
      "risk_addressed": "Git token/password leaked in logs",
      "preconditions": "Git remote configured with credentials",
      "steps": [
        "Configure remote with HTTPS URL containing token",
        "Perform git operations",
        "Check all log output",
        "Verify no credentials in logs"
      ],
      "expected_outcomes": [
        "Credentials redacted in logs",
        "Token/password not visible in any output",
        "Error messages also redact credentials"
      ],
      "priority": "critical"
    },
    {
      "id": "git_security_002",
      "status": "not_started",
      "title": "SSH key passphrase handling",
      "description": "SSH keys with passphrase must prompt or fail gracefully",
      "modules": ["git"],
      "risk_addressed": "Passphrase stored in memory and logged",
      "preconditions": "Git repo with SSH remote requiring passphrase",
      "steps": [
        "Configure SSH key with passphrase",
        "Attempt git operation",
        "Verify passphrase handling is secure"
      ],
      "expected_outcomes": [
        "Passphrase not stored in memory longer than needed",
        "Passphrase not logged",
        "Failed passphrase does not crash"
      ],
      "priority": "high"
    },
    {
      "id": "git_branch_001",
      "status": "not_started",
      "title": "Checkout to new branch creates it",
      "description": "Checkout -b must create and switch to new branch",
      "modules": ["git"],
      "steps": [
        "Call checkout('new-branch', create=true)",
        "Verify new branch exists",
        "Verify current_branch() is new-branch"
      ],
      "expected_outcomes": [
        "Branch created",
        "Switched to new branch",
        "No detached HEAD state"
      ],
      "priority": "medium"
    },
    {
      "id": "git_branch_002",
      "status": "not_started",
      "title": "Checkout failure on uncommitted changes",
      "description": "Must handle or refuse checkout with dirty working tree",
      "modules": ["git"],
      "risk_addressed": "Uncommitted changes lost on checkout",
      "preconditions": "Repo with uncommitted changes",
      "steps": [
        "Make changes, don't commit",
        "Attempt checkout to different branch",
        "Verify error OR changes stashed",
        "Verify changes not lost"
      ],
      "expected_outcomes": [
        "Checkout refused OR changes stashed",
        "Changes preserved",
        "Error message explains what happened"
      ],
      "priority": "high"
    },
    {
      "id": "git_rebase_001",
      "status": "not_started",
      "title": "Rebase conflict handling",
      "description": "Rebase conflicts must be reported and handled gracefully",
      "modules": ["git"],
      "risk_addressed": "Unresolved rebase conflict left in repo",
      "preconditions": "Two branches with conflicting changes",
      "steps": [
        "Start rebase operation",
        "Simulate conflict",
        "Verify conflict reported to user",
        "Resolve conflict",
        "Continue rebase",
        "Verify final state correct"
      ],
      "expected_outcomes": [
        "Conflict detected and reported",
        "Rebase pauses for resolution",
        "Completed rebase leaves clean state"
      ],
      "priority": "high"
    },
    {
      "id": "git_remote_001",
      "status": "not_started",
      "title": "Remote operation timeout",
      "description": "Network failures during remote operations handled",
      "modules": ["git"],
      "risk_addressed": "Agent hangs on slow/unreachable remote",
      "preconditions": "Git remote configured",
      "steps": [
        "Configure network timeout",
        "Block network access",
        "Attempt fetch/push/pull",
        "Verify timeout error returned"
      ],
      "expected_outcomes": [
        "Timeout fires after configured duration",
        "Error returned, not hang",
        "Repo state unchanged after timeout"
      ],
      "priority": "high"
    },
    {
      "id": "git_remote_002",
      "status": "not_started",
      "title": "Push to remote with divergent history",
      "description": "Push rejected when remote has diverged - must handle",
      "modules": ["git"],
      "risk_addressed": "Force push overwrites remote changes accidentally",
      "preconditions": "Local and remote have diverged",
      "steps": [
        "Make divergent changes",
        "Attempt push",
        "Verify push rejected",
        "Fetch and merge or rebase",
        "Verify push succeeds after merge"
      ],
      "expected_outcomes": [
        "Divergent push rejected (not forced)",
        "Error explains divergence",
        "Resolution leaves correct history"
      ],
      "priority": "medium"
    },
    {
      "id": "git_state_001",
      "status": "not_started",
      "title": "Detached HEAD state handling",
      "description": "Manager must handle or prevent detached HEAD",
      "modules": ["git"],
      "risk_addressed": "Work lost in detached HEAD state",
      "preconditions": "Repo in detached HEAD",
      "steps": [
        "Checkout specific commit (detached HEAD)",
        "Verify current_branch() returns null or special value",
        "Make changes",
        "Attempt checkout to branch",
        "Verify changes preserved"
      ],
      "expected_outcomes": [
        "Detached HEAD detected",
        "Warning issued",
        "Changes preserved when leaving detached state"
      ],
      "priority": "medium"
    },
    {
      "id": "git_gh_001",
      "status": "not_started",
      "title": "GitHub API rate limit handling",
      "description": "GitHub API rate limit errors handled correctly",
      "modules": ["git"],
      "risk_addressed": "Rate limit causing failures without retry",
      "preconditions": "GitHub token with known rate limit",
      "steps": [
        "Exhaust rate limit",
        "Attempt GitHub API call",
        "Verify 403 with rate limit info returned",
        "Wait or use different token",
        "Verify retry succeeds"
      ],
      "expected_outcomes": [
        "Rate limit error returned with reset time",
        "Retry after reset succeeds",
        "No hanging or retry storms"
      ],
      "priority": "medium"
    },
    {
      "id": "git_gh_002",
      "status": "not_started",
      "title": "GitHub token permissions validation",
      "description": "Insufficient token permissions return clear error",
      "modules": ["git"],
      "risk_addressed": "Silent failure when token lacks permissions",
      "preconditions": "GitHub token with limited scope",
      "steps": [
        "Use token without 'repo' scope for private repo",
        "Attempt private repo operation",
        "Verify error indicates permission issue"
      ],
      "expected_outcomes": [
        "Permission error returned",
        "Error message indicates scope needed",
        "Not confused with auth failure"
      ],
      "priority": "medium"
    }
  ],
  "test_metadata": {
    "module": "git",
    "crate": "opencode-git",
    "source": "crates/git/src/lib.rs",
    "total_cases": 14,
    "category": "utility",
    "critical_invariants": [
      "Git credentials never logged",
      "Uncommitted changes not lost on checkout",
      "Remote operation timeouts work"
    ],
    "high_risk_scenarios": [
      "git_security_001: Token leaked in logs",
      "git_branch_002: Uncommitted changes lost",
      "git_remote_001: Remote hang"
    ]
  }
}