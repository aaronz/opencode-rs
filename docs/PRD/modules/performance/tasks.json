{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "performance",
  "description": "Performance and load test case designs - latency, throughput, resource bounds under stress",
  "test_cases": [
    {
      "id": "perf_agent_001",
      "status": "requires_infrastructure",
      "title": "Agent response latency under load",
      "description": "Agent response time with N concurrent sessions",
      "modules": ["agent"],
      "risk_addressed": "System too slow under production load",
      "preconditions": "Server with 4 CPU cores, 8GB RAM",
      "test_data": [
        {"sessions": 1, "expected_p50_ms": 500, "expected_p99_ms": 2000},
        {"sessions": 10, "expected_p50_ms": 1000, "expected_p99_ms": 5000},
        {"sessions": 50, "expected_p50_ms": 3000, "expected_p99_ms": 15000}
      ],
      "steps": [
        "Start server",
        "Create N concurrent sessions",
        "Each session sends message simultaneously",
        "Measure response time per session",
        "Calculate p50, p95, p99 latencies"
      ],
      "expected_outcomes": [
        "Latency within SLA bounds",
        "No requests timeout",
        "System stable under load"
      ],
      "oracle_checks": [
        "p99 < 5x p50",
        "No error rate increase under load",
        "Memory stable (no leak)"
      ],
      "priority": "critical"
    },
    {
      "id": "perf_storage_001",
      "status": "requires_infrastructure",
      "title": "Storage throughput - sessions per second",
      "description": "Storage layer can handle target session operations per second",
      "modules": ["storage"],
      "risk_addressed": "Storage becomes bottleneck under load",
      "preconditions": "SQLite with WAL mode",
      "test_data": [
        {"ops/sec": 100, "duration_sec": 60, "expected_success_rate": 0.99},
        {"ops/sec": 500, "duration_sec": 60, "expected_success_rate": 0.95},
        {"ops/sec": 1000, "duration_sec": 30, "expected_success_rate": 0.90}
      ],
      "steps": [
        "Pre-populate storage with 1000 sessions",
        "Run sustained write workload at target ops/sec",
        "Measure actual throughput achieved",
        "Measure error rate"
      ],
      "expected_outcomes": [
        "Achieves target throughput",
        "Error rate below threshold",
        "No deadlocks"
      ],
      "oracle_checks": [
        "WAL mode enabled",
        "Connection pool sized correctly",
        "No lock contention errors"
      ],
      "priority": "high"
    },
    {
      "id": "perf_memory_001",
      "status": "requires_infrastructure",
      "title": "Memory usage under sustained session churn",
      "description": "Memory must not grow unbounded with session create/destroy",
      "modules": ["agent", "session", "storage"],
      "risk_addressed": "Memory leak causes OOM over time",
      "preconditions": "Server with 2GB memory limit",
      "test_data": [
        {"iterations": 1000, "session_size": "small"},
        {"iterations": 500, "session_size": "large (1000 messages)"}
      ],
      "steps": [
        "Start fresh server",
        "Record initial memory (RSS)",
        "Create session, run agent, destroy session",
        "Repeat N times",
        "Record memory every 100 iterations",
        "End state: memory after cleanup"
      ],
      "expected_outcomes": [
        "Memory growth < 10MB per 100 iterations",
        "Final memory close to initial (< 50MB delta)",
        "No memory leak detected"
      ],
      "oracle_checks": [
        "RSS growth is bounded",
        "Heap profiling shows no leaks",
        "Arena allocators reset between sessions"
      ],
      "priority": "critical"
    },
    {
      "id": "perf_memory_002",
      "status": "requires_infrastructure",
      "title": "Session compaction memory spike",
      "description": "Compaction must not spike memory beyond limit",
      "modules": ["session", "storage"],
      "risk_addressed": "Compaction causes OOM spike",
      "preconditions": "Session with 10,000 messages",
      "test_data": [
        {"messages": 10000, "allowed_memory_mb": 500}
      ],
      "steps": [
        "Pre-create session with 10000 messages",
        "Record baseline memory",
        "Trigger compaction",
        "Measure peak memory during compaction",
        "Measure steady-state memory after compaction"
      ],
      "expected_outcomes": [
        "Peak memory < 500MB during compaction",
        "Memory returns to near-baseline after",
        "Compaction completes without OOM"
      ],
      "oracle_checks": [
        "Streaming compaction algorithm",
        "Not loading all messages into memory at once",
        "Immediate cleanup after compaction"
      ],
      "priority": "high"
    },
    {
      "id": "perf_provider_001",
      "status": "requires_infrastructure",
      "title": "Provider streaming throughput",
      "description": "Streaming response processing keeps up with provider",
      "modules": ["provider"],
      "risk_addressed": "Streaming buffer fills, blocks provider",
      "preconditions": "Provider with streaming API",
      "test_data": [
        {"tokens_per_sec": 100, "buffer_ms": 5000},
        {"tokens_per_sec": 1000, "buffer_ms": 5000},
        {"tokens_per_sec": 10000, "buffer_ms": 5000}
      ],
      "steps": [
        "Provider streams at tokens_per_sec",
        "Client processes stream",
        "Measure end-to-end latency",
        "Verify buffer not filling up"
      ],
      "expected_outcomes": [
        "Buffer never fills completely",
        "Backpressure applied to provider if needed",
        "No tokens dropped"
      ],
      "oracle_checks": [
        "Buffer has max capacity",
        "Backpressure signals to provider",
        "Overflow handled gracefully"
      ],
      "priority": "medium"
    },
    {
      "id": "perf_concurrent_001",
      "status": "requires_infrastructure",
      "title": "Maximum concurrent WebSocket connections",
      "description": "System supports target concurrent WebSocket connections",
      "modules": ["server"],
      "risk_addressed": "WebSocket limit exceeded causes connection failures",
      "preconditions": "Server with default config",
      "test_data": [
        {"connections": 100, "expected_all_healthy": true},
        {"connections": 500, "expected_all_healthy": true},
        {"connections": 1000, "expected_all_healthy": false, "reason": "may exceed ulimit"}
      ],
      "steps": [
        "Start server",
        "Spawn N WebSocket connections to /ws/{session_id}",
        "Each connection sends message every 1s",
        "Verify all connections receive broadcasts",
        "Measure connection setup time"
      ],
      "expected_outcomes": [
        "100 connections: all healthy",
        "500 connections: all healthy",
        "Setup time < 100ms per connection"
      ],
      "oracle_checks": [
        "No FD exhaustion",
        "Memory scales linearly with connections",
        "Broadcast latency O(1) or O(log n)"
      ],
      "priority": "high"
    },
    {
      "id": "perf_database_001",
      "status": "requires_infrastructure",
      "title": "SQLite query latency - session list pagination",
      "description": "list_sessions with pagination completes in bounded time",
      "modules": ["storage"],
      "risk_addressed": "Pagination query slows to unacceptable",
      "preconditions": "Storage with 100,000 sessions",
      "test_data": [
        {"sessions": 100000, "limit": 50, "offset": 0},
        {"sessions": 100000, "limit": 50, "offset": 50000},
        {"sessions": 100000, "limit": 50, "offset": 99950}
      ],
      "steps": [
        "Create 100,000 sessions",
        "Execute paginated query with various offsets",
        "Measure query time"
      ],
      "expected_outcomes": [
        "Offset 0: < 50ms",
        "Offset 50000: < 100ms",
        "Offset 99950: < 100ms",
        "Uses indexes, not full scan"
      ],
      "oracle_checks": [
        "Indexes on created_at, agent_type",
        "No OFFSET with large skip (use keyset pagination)",
        "Query plan uses index"
      ],
      "priority": "medium"
    },
    {
      "id": "perf_startup_001",
      "status": "requires_infrastructure",
      "title": "Cold start latency",
      "description": "System starts and accepts requests within SLA",
      "modules": ["server", "storage"],
      "risk_addressed": "Startup too slow for serverless/container environments",
      "preconditions": "Fresh deployment",
      "test_data": [
        {"target_startup_ms": 5000},
        {"target_first_request_ms": 1000}
      ],
      "steps": [
        "Kill server process",
        "Start server",
        "Time until accepting connections",
        "Send first API request",
        "Time until response"
      ],
      "expected_outcomes": [
        "Server accepting connections < 5s",
        "First API response < 1s after startup",
        "No eager initialization of unused components"
      ],
      "oracle_checks": [
        "Lazy initialization where possible",
        "WAL checkpoint deferred until needed",
        "LSP servers not started until needed"
      ],
      "priority": "medium"
    },
    {
      "id": "perf_tool_001",
      "status": "requires_infrastructure",
      "title": "Tool execution latency - hot path",
      "description": "Common tools (read, glob) have minimal latency",
      "modules": ["tool"],
      "risk_addressed": "File tools too slow for interactive use",
      "preconditions": "Project with 10,000 files",
      "test_data": [
        {"tool": "read", "file_size_kb": 1, "expected_ms": 5},
        {"tool": "read", "file_size_kb": 100, "expected_ms": 20},
        {"tool": "glob", "pattern": "**/*.rs", "expected_ms": 100},
        {"tool": "grep", "pattern": "fn ", "expected_ms": 200}
      ],
      "steps": [
        "Set up project with 10,000 files",
        "Execute each tool measurement",
        "Measure wall time"
      ],
      "expected_outcomes": [
        "1KB read: < 5ms",
        "100KB read: < 20ms",
        "Glob: < 100ms",
        "Grep: < 200ms"
      ],
      "oracle_checks": [
        "Results cached where appropriate",
        "No unnecessary stat() calls",
        "Memory-mapped files for large reads"
      ],
      "priority": "medium"
    },
    {
      "id": "perf_lsp_001",
      "status": "requires_infrastructure",
      "title": "LSP diagnostics latency",
      "description": "Diagnostics update within acceptable time of file change",
      "modules": ["lsp"],
      "risk_addressed": "LSP diagnostics stale or slow",
      "preconditions": "Rust project with rust-analyzer",
      "test_data": [
        {"file_change": "edit 1 line", "expected_diagnostic_update_ms": 1000},
        {"file_change": "edit 10 lines", "expected_diagnostic_update_ms": 3000},
        {"file_change": "add import", "expected_diagnostic_update_ms": 2000}
      ],
      "steps": [
        "Open project in editor",
        "Wait for initial diagnostics",
        "Make file change",
        "Time until diagnostics updated"
      ],
      "expected_outcomes": [
        "Single line edit: < 1s update",
        "No diagnostic lag > 5s for any change"
      ],
      "oracle_checks": [
        "rust-analyzer debounce: 300ms",
        "No full reanalysis on small edits",
        "Diagnostics cached per-file"
      ],
      "priority": "low"
    }
  ],
  "test_metadata": {
    "module": "performance",
    "description": "Performance and load testing scenarios",
    "total_cases": 10,
    "category": "performance",
    "critical_invariants": [
      "Memory bounded under session churn",
      "p99 latency within 5x p50",
      "Startup < 5s"
    ],
    "high_risk_scenarios": [
      "perf_memory_001: Memory leak causing OOM",
      "perf_agent_001: Latency SLA breach under load",
      "perf_startup_001: Cold start too slow"
    ],
    "slas": {
      "response_time_p99": "5x p50",
      "error_rate_under_load": "< 1%",
      "memory_growth_per_100_iterations": "< 10MB",
      "startup_time": "< 5s"
    }
  }
}