      "expected_outcomes": [
        "Auth errors returned to caller",
        "No command executed without auth"
      ],
      "priority": "critical",
      "notes": "MCP client handles auth errors via handler pattern"
    },
    {
      "id": "mcp_sec_002",
      "status": "completed",
      "title": "MCP server authentication",
      "description": "MCP server must authenticate clients",
      "modules": ["mcp"],
      "test_file": "crates/mcp/tests/mcp_e2e_tests.rs",
      "test_modules": ["mcp_security_tests"],
      "risk_addressed": "Unauthorized MCP server access",
      "steps": [
