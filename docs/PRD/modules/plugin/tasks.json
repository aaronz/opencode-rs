{
  "$schema": "https://tasks.opencode.dev/schema",
  "version": "1.0",
  "module": "plugin",
  "description": "E2E test case designs for opencode-plugin crate - WASM plugin system",
  "test_cases": [
    {
      "id": "plugin_e2e_001",
      "status": "completed",
      "title": "Plugin loading and initialization",
      "description": "Test WASM plugin loads and registers tools",
      "modules": ["plugin"],
      "steps": [
        "Compile plugin to WASM",
        "Load plugin via PluginLoader",
        "Call plugin_init()",
        "Verify tools registered"
      ],
      "expected_outcomes": [
        "Plugin loads without error",
        "Tools become available in registry"
      ]
    },
    {
      "id": "plugin_e2e_002",
      "status": "completed",
      "title": "Plugin lifecycle hooks",
      "description": "Test plugin lifecycle event callbacks",
      "modules": ["plugin"],
      "steps": [
        "Load plugin with hooks",
        "Trigger on_start event",
        "Trigger on_tool_call event",
        "Verify hooks called with correct context"
      ],
      "expected_outcomes": [
        "Hooks called at appropriate times",
        "Context data correct"
      ]
    },
    {
      "id": "plugin_sec_001",
      "status": "requires_code_change",
      "title": "CRITICAL: WASM plugin sandbox escapes must be prevented",
      "description": "Plugin must not escape WASM sandbox to access host resources",
      "modules": ["plugin"],
      "risk_addressed": "Plugin gains unauthorized host access via WASM exploit",
      "preconditions": "Plugin loaded in wasmi",
      "test_data": [
        {"attempt": "memory corruption via wasm", "expected": "blocked"},
        {"attempt": "pointer arithmetic out of bounds", "expected": "blocked"},
        {"attempt": "importing dangerous host functions", "expected": "blocked"}
      ],
      "steps": [
        "Load plugin with malformed WASM",
        "Attempt to access host via exported functions",
        "Verify sandbox enforced"
      ],
      "expected_outcomes": [
        "Malformed WASM rejected at load",
        "Dangerous imports blocked",
        "Plugin isolated from host"
      ],
      "priority": "critical"
    },
    {
      "id": "plugin_sec_002",
      "status": "requires_code_change",
      "title": "Plugin resource limits",
      "description": "WASM execution must have bounded CPU/memory",
      "modules": ["plugin"],
      "risk_addressed": "Plugin consumes infinite CPU or memory",
      "preconditions": "Plugin with infinite loop",
      "steps": [
        "Execute plugin with CPU-intensive operation",
        "Execute plugin with memory allocation",
        "Verify limits enforced"
      ],
      "expected_outcomes": [
        "CPU time limited",
        "Memory allocation limited",
        "Exceed limits -> error, not hang"
      ],
      "priority": "critical"
    },
    {
      "id": "plugin_sec_003",
      "status": "completed",
      "title": "Plugin tool registration validation",
      "description": "Registered tools must have valid schemas",
      "modules": ["plugin"],
      "risk_addressed": "Malformed tool schema causes crashes",
      "preconditions": "Plugin returns invalid tool schema",
      "test_data": [
        {"schema": "not valid JSON schema", "issue": "invalid"},
        {"schema": "{\"type\": \"invalid_type\"}", "issue": "unknown type"},
        {"schema": "{\"parameters\": null}", "issue": "null params"}
      ],
      "steps": [
        "Plugin registers tool with invalid schema",
        "Verify registration fails with error",
        "Verify no crash"
      ],
      "expected_outcomes": [
        "Invalid schema rejected",
        "Error descriptive",
        "Plugin load fails gracefully"
      ],
      "priority": "high"
    },
    {
      "id": "plugin_state_001",
      "status": "completed",
      "title": "Plugin init called only once",
      "description": "plugin_init must not be called multiple times per instance",
      "modules": ["plugin"],
      "risk_addressed": "Double init causes resource leaks",
      "preconditions": "Plugin loaded",
      "steps": [
        "Call plugin_init() once",
        "Call plugin_init() again on same instance",
        "Verify error OR second call ignored"
      ],
      "expected_outcomes": [
        "Second init returns error OR ignored",
        "Resources not duplicated",
        "State consistent"
      ],
      "priority": "medium"
    },
    {
      "id": "plugin_state_002",
      "status": "completed",
      "title": "Plugin cleanup on unload",
      "description": "Unloaded plugin must release all resources",
      "modules": ["plugin"],
      "risk_addressed": "Plugin resources leak after unload",
      "preconditions": "Plugin loaded and executed",
      "steps": [
        "Load and execute plugin",
        "Unload plugin",
        "Verify memory freed",
        "Verify no dangling references"
      ],
      "expected_outcomes": [
        "Memory returned to system",
        "File handles closed",
        "No zombie resources"
      ],
      "priority": "high"
    },
    {
      "id": "plugin_hooks_001",
      "status": "completed",
      "title": "on_tool_call hook can block tool execution",
      "description": "Plugin hook must be able to deny tool calls",
      "modules": ["plugin"],
      "risk_addressed": "Hook unable to prevent dangerous tool calls",
      "preconditions": "Plugin with on_tool_call hook that returns deny",
      "steps": [
        "Register hook that blocks write operations",
        "Attempt write operation",
        "Verify hook blocks it",
        "Verify block logged"
      ],
      "expected_outcomes": [
        "Hook can return block decision",
        "Tool call rejected",
        "Reason logged"
      ],
      "priority": "high"
    },
    {
      "id": "plugin_hooks_002",
      "status": "completed",
      "title": "on_message hook message modification",
      "description": "Plugin can modify messages via hook",
      "modules": ["plugin"],
      "risk_addressed": "Hook modifies messages unexpectedly",
      "preconditions": "Plugin with on_message hook that modifies content",
      "steps": [
        "Send message through hook",
        "Verify modification applied",
        "Verify original not mutated"
      ],
      "expected_outcomes": [
        "Modification visible to receiver",
        "Original message preserved",
        "Modifications traceable"
      ],
      "priority": "medium"
    }
  ],
  "test_metadata": {
    "module": "plugin",
    "crate": "opencode-plugin",
    "source": "crates/plugin/src/lib.rs",
    "total_cases": 11,
    "category": "integration",
    "critical_invariants": [
      "WASM sandbox enforced, no escape",
      "Plugin resource usage bounded",
      "Plugin init called exactly once"
    ],
    "high_risk_scenarios": [
      "plugin_sec_001: WASM sandbox escape",
      "plugin_sec_002: Resource exhaustion"
    ]
  }
}