{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode config fallback schema",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    }
  },
  "additionalProperties": true
}
